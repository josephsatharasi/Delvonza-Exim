PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/delvonza?retryWrites=true&w=majority&appName=delvonza
CLIENT_URLS=http://localhost:3000,http://localhost:3001
# Used for Stripe Checkout return URLs (defaults to first CLIENT_URLS entry)
STRIPE_FRONTEND_URL=http://localhost:3000
JWT_ACCESS_SECRET=replace_with_strong_access_secret
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d

# Admin panel JWT (defaults to JWT_ACCESS_SECRET if unset)
ADMIN_JWT_SECRET=replace_with_strong_admin_secret_or_same_as_jwt_access
ADMIN_TOKEN_EXPIRES=12h
# HMAC pepper for password-reset OTP (required in production)
ADMIN_OTP_SECRET=replace_with_random_string
# Dev only: log OTP to server console (never enable in production)
# ADMIN_OTP_LOG=true

# Forgot-password mail — Nodemailer + Gmail only (no SMTP host/port; use Google App Password)
EMAIL_USER=you@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx
# MAIL_FROM=you@gmail.com

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
# Stripe — use test keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
# Optional: defaults to inr; use usd, eur, etc. if your Stripe account uses that currency
STRIPE_CURRENCY=inr
